# -------------------
# 4. State
# -------------------
class ChatSchema(TypedDict):
    messages: Annotated[list[BaseMessage], add_messages]

# -------------------
# 5. Nodes
# -------------------
def generate_chat(state: ChatSchema, config=None) -> ChatSchema:
    thread_id = None
    if config and isinstance(config, dict):
        thread_id = config.get("configurable", {}).get("thread_id")

    system_message = SystemMessage(
        content=(
            "You are a helpful assistant. "
            "For questions about uploaded PDF, call `rag_tool` with the thread_id "
            f"`{thread_id}`. "
            "You can also use web search, stock price, and calculator tools."
            "If no document is uploaded, ask user to upload a PDF."
        )
    )
    messages = [system_message, *state["messages"]]
    response = llm_with_tools.invoke(messages, config=config)
    return {"messages": [response]}

tool_node = ToolNode(tools)

